generator client {
  provider        = "prisma-client-js"
  output          = "../src/generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model County {
  id          Int             @id @default(autoincrement())
  name        String          @unique
  isBeachPlan Boolean         @default(false)
  carriers    CarrierCounty[]
}

model Carrier {
  id                    Int             @id @default(autoincrement())
  name                  String          @unique
  rating                String
  type                  String          @default("Admitted")
  website               String?
  maxDwelling           Int?
  minDwelling           Int?
  maxHomeAge            Int?
  maxRoofAge            Int?
  generalUwNotes        String?
  writesPrimary         Boolean         @default(true)
  writesSecondary       Boolean         @default(false)
  writesShortTermRental Boolean         @default(false)
  writesTenantOccupied  Boolean         @default(false)
  counties              CarrierCounty[]
}

model CarrierCounty {
  id        Int     @id @default(autoincrement())
  carrierId Int
  countyId  Int
  carrier   Carrier @relation(fields: [carrierId], references: [id])
  county    County  @relation(fields: [countyId], references: [id])

  appetiteLevel      String
  windHailStance     String
  windHailDetail     String?
  minDwelling        Int?
  constructionNote   String?
  maxProtectionClass Int?
  uwNotes            String?
  updatedAt          DateTime @updatedAt

  @@unique([carrierId, countyId])
  @@index([countyId])
}
